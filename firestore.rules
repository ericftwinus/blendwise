rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Block all global reads/writes by default
    match /{document=**} {
      allow read, write: if false;
    }

    // Conversations: only participants can read/write
    match /conversations/{conversationId} {
      allow read: if request.auth != null
        && request.auth.uid in resource.data.participants;
      allow create: if request.auth != null
        && request.auth.uid in request.resource.data.participants;
      allow update: if request.auth != null
        && request.auth.uid in resource.data.participants;

      // Messages subcollection
      match /messages/{messageId} {
        allow read: if request.auth != null
          && request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants;
        allow create: if request.auth != null
          && request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants
          && request.resource.data.senderId == request.auth.uid;
      }
    }

    // Calls: only caller or callee can access
    match /calls/{callId} {
      allow get: if request.auth != null
        && (request.auth.uid == resource.data.callerId
            || request.auth.uid == resource.data.calleeId);
      allow list: if request.auth != null;
      allow create: if request.auth != null
        && request.auth.uid == request.resource.data.callerId;
      allow update: if request.auth != null
        && (request.auth.uid == resource.data.callerId
            || request.auth.uid == resource.data.calleeId);

      // ICE candidates for caller
      match /callerCandidates/{candidateId} {
        allow read, write: if request.auth != null
          && (request.auth.uid == get(/databases/$(database)/documents/calls/$(callId)).data.callerId
              || request.auth.uid == get(/databases/$(database)/documents/calls/$(callId)).data.calleeId);
      }

      // ICE candidates for callee
      match /calleeCandidates/{candidateId} {
        allow read, write: if request.auth != null
          && (request.auth.uid == get(/databases/$(database)/documents/calls/$(callId)).data.callerId
              || request.auth.uid == get(/databases/$(database)/documents/calls/$(callId)).data.calleeId);
      }
    }

    // Mail: clients can create (queue) emails, only admin/server can read
    // The "Trigger Email" extension uses Admin SDK so it bypasses rules
    match /mail/{mailId} {
      allow create: if request.auth != null;
    }

    // Education content: any authenticated user can read, no client writes
    match /education_content/{videoId} {
      allow read: if request.auth != null;
    }

    // Video progress: users can only read/write their own progress
    match /user_video_progress/{userId}/videos/{videoId} {
      allow read, write: if request.auth != null
        && request.auth.uid == userId;
    }
  }
}
